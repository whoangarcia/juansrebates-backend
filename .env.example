# Copy to .env (gitignored) for local development. Never commit real values.

# Google Sheets — service account key as single-line JSON, OR place file at secrets/service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=

# MiniCRM target sheet
SHEET_ID=1ulM7OyW1eTkxErfqbmCHQaWYDYthk9FyGW4pHb-Na_k

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=https://juansrebates.com,https://www.juansrebates.com,https://juansrebates.netlify.app

# Resend (email notifications). Leave empty to disable.
RESEND_API_KEY=
NOTIFY_EMAIL=
FROM_EMAIL=juansrebates <onboarding@resend.dev>

# Server port (Render sets this automatically)
PORT=8000
